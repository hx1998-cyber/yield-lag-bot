# Copy to .env and fill in. NEVER commit real secrets.
# Env vars prefixed with BACCARAT_ override values from config/settings.yaml.

# ---------- Wallet ----------
# 0x-prefixed hex string, 64 chars. The bot reads this once at startup and
# keeps it only in memory. Use Docker secrets in production.
PRIVATE_KEY=

# ---------- Polygon RPC ----------
# Comma-separated list. Order = priority. Free public RPCs are fine for dev,
# but for production buy a paid endpoint (Alchemy / Infura / QuickNode).
BACCARAT_NETWORK__RPC_ENDPOINTS=https://polygon-rpc.com,https://rpc.ankr.com/polygon

# ---------- Database ----------
POSTGRES_DB=baccarat
POSTGRES_USER=baccarat
POSTGRES_PASSWORD=changeme-strong-password
# Used by the bot directly (overrides docker-compose value when running locally).
BACCARAT_DATABASE_URL=postgresql+asyncpg://baccarat:changeme-strong-password@localhost:5432/baccarat

# ---------- Redis ----------
BACCARAT_REDIS_URL=redis://localhost:6379/0

# ---------- Telegram alerting ----------
BACCARAT_ALERTING__TELEGRAM_BOT_TOKEN=
# chat_id can also be set here to override settings.yaml
# BACCARAT_ALERTING__TELEGRAM_CHAT_ID=

# ---------- Optional: which yaml to load ----------
BACCARAT_CONFIG_FILE=config/settings.yaml
