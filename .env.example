# Copy to .env for local overrides. Do not add real exchange keys.
# Env vars prefixed with YIELD_LAG_ override M1 defaults.

POSTGRES_DB=yield_lag
POSTGRES_USER=yield_lag
POSTGRES_PASSWORD=yield_lag

YIELD_LAG_DATABASE_URL=postgresql+asyncpg://yield_lag:yield_lag@localhost:5432/yield_lag
YIELD_LAG_REDIS_URL=redis://localhost:6379/0

YIELD_LAG_LIVE_TRADING=false
YIELD_LAG_PAPER_TRADING=true
YIELD_LAG_MAX_ORDER_USD=10
YIELD_LAG_MAX_POSITION_USD=50
YIELD_LAG_MAX_DAILY_LOSS_USD=20
YIELD_LAG_MAX_LATENCY_MS=300
YIELD_LAG_STALE_DATA_MS=500
YIELD_LAG_KILL_SWITCH_ON_ERROR=true

YIELD_LAG_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT
YIELD_LAG_HYPERLIQUID_SYMBOLS=BTC,ETH
YIELD_LAG_CME_SYMBOLS=ZT,ZF,ZN,TN
YIELD_LAG_HYPERLIQUID_NETWORK=mainnet
YIELD_LAG_HYPERLIQUID_MAINNET_WS_URL=wss://api.hyperliquid.xyz/ws
YIELD_LAG_HYPERLIQUID_TESTNET_WS_URL=wss://api.hyperliquid-testnet.xyz/ws

DATABENTO_API_KEY=
